{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "Represents a customer's product order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerAddress": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "customerEmail", "customerPhone", "customerAddress", "items", "totalAmount"]
    },
    "User": {
      "title": "User",
      "description": "Application user details and permissions.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "A shop product item.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "subCategory": { "type": "string" },
        "subCategory2": { "type": "string" },
        "image": { "type": "string" },
        "stock": { "type": "number" },
        "featured": { "type": "boolean" }
      },
      "required": ["name", "price", "category", "image"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category definition.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "image": { "type": "string", "description": "Base64 or URL of category image" },
        "parentId": { "type": "string", "description": "ID of parent category for sub-categories" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "image"]
    },
    "Setting": {
      "title": "Setting",
      "description": "General application settings.",
      "type": "object",
      "properties": {
        "slider": { "type": "array" },
        "banners": { 
          "type": "array",
          "description": "Two column banners shown below the main slider"
        },
        "footer": {
          "type": "object",
          "properties": {
            "phone": { "type": "string" },
            "email": { "type": "string" },
            "address": { "type": "string" },
            "facebook": { "type": "string" },
            "twitter": { "type": "string" },
            "instagram": { "type": "string" },
            "youtube": { "type": "string" }
          }
        },
        "hotOfferExpiry": { "type": "string" }
      }
    },
    "Review": {
      "title": "Review",
      "description": "A product review from a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "userName", "rating", "comment"]
    }
  },
  "firestore": {
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection for all customer orders."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection for user data."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection for products."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection for categories."
    },
    "/settings/{settingId}": {
      "schema": "Setting",
      "description": "App settings (e.g., homepage configuration)."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collection for product reviews."
    }
  }
}
